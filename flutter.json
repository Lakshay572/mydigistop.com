{
  "api": {
    "name": "Microsoft CID Activation API",
    "base_url": "https://getcid.info/api",
    "method": "GET",
    "endpoint": "/{iid}/{token}",
    "parameters": {
      "iid": {
        "type": "string",
        "required": true,
        "description": "Microsoft Installation ID"
      },
      "token": {
        "type": "string",
        "required": true,
        "description": "API Verification Token"
      }
    }
  },

  "request_example": {
    "url": "https://getcid.info/api/539979038249031308832790330685369121397625732562087764155620325/test1234567"
  },

  "responses": {
    "success": {
      "status": "success",
      "cid": "260150672771490322851855366226271886248373443125"
    },

    "activation_errors": [
      {
        "status": "error",
        "message": "Wrong IID."
      },
      {
        "status": "error",
        "message": "Blocked IID."
      },
      {
        "status": "error",
        "message": "Exceeded IID."
      },
      {
        "status": "error",
        "message": "Need to call M$ Support."
      },
      {
        "status": "error",
        "message": "Not legimate key. Maybe blocked."
      }
    ],

    "rate_limit_errors": [
      {
        "status": "error",
        "message": "Your IP reach request limit."
      },
      {
        "status": "error",
        "message": "Your IP is being locked."
      },
      {
        "status": "error",
        "message": "Your IID reach request limit."
      },
      {
        "status": "error",
        "message": "Your IID is being locked."
      }
    ],

    "token_errors": [
      {
        "status": "error",
        "message": "Sorry, API Token cannot be empty."
      },
      {
        "status": "error",
        "message": "Sorry, your API Token does not exist."
      },
      {
        "status": "error",
        "message": "Sorry, your API Token has been used 5/5 times."
      }
    ],

    "server_errors": [
      {
        "status": "error",
        "message": "Server too busy."
      }
    ]
  },

  "redeem_api": {
    "name": "Microsoft Key Status Check",
    "description": "Check if a digital key is still available",
    "responses": [
      {
        "status": "Redeemed",
        "message": "Redeemed"
      },
      {
        "status": "Active",
        "message": "Available"
      }
    ]
  },

  "frontend_config": {
    "fields": [
      {
        "name": "Installation ID",
        "id": "iid",
        "type": "text",
        "required": true
      },
      {
        "name": "API Token",
        "id": "token",
        "type": "password",
        "required": true
      }
    ],
    "buttons": [
      {
        "name": "Generate CID",
        "action": "call_cid_api"
      },
      {
        "name": "Check Key Status",
        "action": "check_redeem_status"
      }
    ]
  }
}
